      if(-not $NoLoneSpeed -and $pacefit.ContainsKey($nm)){ $lsc= if($cp.ContainsKey($key) -and "$($cp[$key])" -match '^\d+$'){[int]$cp[$key]}else{99}; if($lsc -le 6){ $tot+=$LoneSpeedBoost; $parts+='L' } }
